# Database
DATABASE_URL="file:./dev.db"  # Use PostgreSQL for production: "postgresql://user:pass@host:5432/db"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="development-secret-key-change-in-production"

# Azure AD Configuration
AZURE_AD_CLIENT_ID="your-client-id"
AZURE_AD_CLIENT_SECRET="your-client-secret"
AZURE_AD_TENANT_ID="your-tenant-id"

# Azure AD Callback (must match Azure app redirect URI)
AZURE_CALLBACK_URL="http://localhost:3000/api/auth/callback/azure-ad"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Microsoft Graph API (for email access)
MS_GRAPH_ACCESS_TOKEN="your-graph-token"

# Server
NODE_ENV="development"  # Set to "production" in production
PORT=4000

# Optional: Production PostgreSQL (uncomment for production)
# DATABASE_URL="postgresql://user:password@localhost:5432/logitask?schema=public&sslmode=require"
# NODE_ENV=production
# NEXTAUTH_SECRET=<generate-random-64-character-string>
