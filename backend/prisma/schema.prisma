// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // For local development: use "sqlite" and DATABASE_URL="file:./dev.db"
  // For production/pilot: use "postgresql" and DATABASE_URL="postgresql://..."
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Models - using String instead of enums for SQLite compatibility
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String?
  role        String   @default("RECEPTION_COORDINATOR")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks          Task[]
  comments       TaskComment[]
  auditLogs      AuditLog[]
  statusHistory  TaskStatusHistory[]
  CoordinatorKPI CoordinatorKPI[]
}

model Mailbox {
  id           String   @id @default(uuid())
  emailAddress String   @unique
  displayName  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  emails Email[]
}

// Master Inbox - Еден извор за сите влезни податоци
// Сите модули (Email, ERP, Manual) ги запишуваат податоците тука
// Потоа Task Engine ги обработува и креира tasks
model InboundItem {
  id                    String    @id @default(uuid())
  
  // Извор на податоци
  sourceType             String    // EMAIL, ERP, MANUAL
  sourceSubType        String?   // EMAIL_RECEIVED, ERP_PO, ERP_GR, etc.
  sourceId             String?   // ID од оригиналниот извор (emailId, erpDocumentId, итн)
  sourceData           String?   // JSON со оригиналните податоци
  
  // Статус на обработка
  intakeStatus          String    @default("RECLAIMED")  // RECLAIMED, PROCESSED, FAILED, CANCELLED
  processingStatus      String    @default("RECLAIMED")  // Alias
  processedAt          DateTime?
  processedBy          String?   // User ID
  
  // Екстрактирани податоци (заеднички за сите извори)
  subject             String?
  supplierName         String?
  locationName        String?
  partnerCode         String?   // Добавувач/клиент код
  
  // Време и датуми
  requestedDate       DateTime? // Кога е побарано/планирано
  receivedAt         DateTime  @default(now()) // Кога е примено
  ingestedAt          DateTime? // Кога е ingest-ирано
  
  // Класификација
  requestType         String?   // INBOUND_RECEIPT, OUTBOUND_PREPARATION, OUTBOUND_DELIVERY, TRANSFER_DISTRIBUTION
  priority           String?   // LOW, MEDIUM, HIGH
  classification     String?   // Резултат од ML/AI класификација
  
  // Дополнителни полиња специфични за тип
  note               String?
  referenceNumber    String?   // Број на нарачка/документ
  
  // Task count
  tasksGenerated      Int       @default(0)

  // Inverse relations - other models have inboundItemId pointing to us
  emails              Email[]      @relation("InboundEmail")
  erpDocuments         ErpDocument[] @relation("InboundErpDocument")
  cases                EmailCase[]  @relation("InboundCase")
  tasks                Task[]       @relation("InboundTask")

  // Историја
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  // Индекси за брзо пре baranje
  @@index([sourceType, intakeStatus])
  @@index([sourceType, processingStatus])
  @@index([requestType])
  @@index([supplierName])
  @@index([processedAt])
}

// Model: Email (Record from email inbox - НЕ се користи директно, само за архиви)
model Email {
  id                    String    @id @default(uuid())
  mailboxId             String
  mailbox               Mailbox   @relation(fields: [mailboxId], references: [id])
  microsoftGraphId      String?   @unique
  subject               String
  sender                String
  senderEmail           String
  body                  String?
  bodyPlainText         String?
  receivedAt            DateTime
  processingStatus      String    @default("PENDING")
  extractedSupplier     String?
  extractedLocation     String?
  extractedDeliveryDate DateTime?
  extractedUrgency    String?
  requestType         String    @default("UNCLASSIFIED")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Поврзан inboundItem за централна обработка
  inboundItemId       String?
  inboundItem       InboundItem? @relation("InboundEmail", fields: [inboundItemId], references: [id])
  
  tasks Task[]
  case  EmailCase?
}

model Task {
  id          String    @id @default(uuid())
  emailId     String?
  email       Email?    @relation(fields: [emailId], references: [id])
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  title       String
  description String?
  status      String    @default("PROPOSED")
  requestType String
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Главен извор на податоци (ги заменува emailId, erpDocumentId)
  inboundItemId       String?
  inboundItem       InboundItem? @relation("InboundTask", fields: [inboundItemId], references: [id])

  // New fields for Reports & OTIF module
  assignedAt        DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  completionResult  String? // FULL, PARTIAL, FAILED
  delayReasonCode   String?
  delayReasonText   String?
  isRequiredForCase Boolean   @default(true)

  // ERP Integration (legacy - сега преку InboundItem)
  erpDocumentId String?
  erpDocument   ErpDocument? @relation("ErpDocumentTasks", fields: [erpDocumentId], references: [id])

  // Performance tracking for Coordinator KPIs
  deliveryAccuracy Boolean? // Did delivery match order?
  onTimePrep       Boolean? // Was prep done on time?
  onTimeDelivery   Boolean? // Was delivery on time?
  delayMinutes     Int? // Minutes late (negative = early)

  dependencies  TaskDependency[]    @relation("DependentTask")
  dependents    TaskDependency[]    @relation("DependencyTask")
  comments      TaskComment[]
  auditLogs     AuditLog[]
  statusHistory TaskStatusHistory[]
  
  @@index([inboundItemId])
}

model TaskDependency {
  id           String   @id @default(uuid())
  dependentId  String
  dependent    Task     @relation("DependentTask", fields: [dependentId], references: [id])
  dependencyId String
  dependency   Task     @relation("DependencyTask", fields: [dependencyId], references: [id])
  offsetDays   Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([dependentId, dependencyId])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoutingRule {
  id           String   @id @default(uuid())
  name         String   @unique
  requestType  String
  priority     Int      @default(0)
  conditions   String // Store conditions as JSON string
  assigneeRole String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  action    String
  details   String // Store action details as JSON string
  ipAddress String?
  createdAt DateTime @default(now())
}

// New models for Reports & OTIF module

model EmailCase {
  id                   String    @id @default(uuid())
  emailId              String?   @unique  // Made optional - can use inboundItemId instead
  email                Email?    @relation(fields: [emailId], references: [id])
  
  // Link to Master Inbox (NEW!)
  inboundItemId        String?
  inboundItem          InboundItem? @relation("InboundCase", fields: [inboundItemId], references: [id])
  
  caseStatus           String    @default("NEW") // NEW, PROPOSED, APPROVED, IN_PROGRESS, DONE, PARTIAL, FAILED, CANCELLED
  classification       String? // INBOUND_RECEIPT, OUTBOUND_DELIVERY, DISTRIBUTION, OTHER
  priority             String? // HIGH, MEDIUM, LOW
  supplierName         String?
  locationName         String?
  deliveryDueAt        DateTime?
  caseDueAt            DateTime?
  approvedAt           DateTime?
  completedAt          DateTime?
  isOnTime             Boolean?
  isInFull             Boolean?
  isOtif               Boolean?
  approvalLeadMinutes  Int?
  executionLeadMinutes Int?
  totalTasks           Int       @default(0)
  completedTasks       Int       @default(0)
  partialTasks         Int       @default(0)
  failedTasks          Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([caseStatus])
  @@index([caseDueAt])
  @@index([approvedAt])
  @@index([completedAt])
  @@index([supplierName])
  @@index([locationName])
  @@index([isOtif])
  @@index([inboundItemId])
}

model TaskStatusHistory {
  id              String   @id @default(uuid())
  taskId          String
  task            Task     @relation(fields: [taskId], references: [id])
  fromStatus      String?
  toStatus        String
  changedByUserId String?
  changedBy       User?    @relation(fields: [changedByUserId], references: [id])
  changedAt       DateTime @default(now())
  note            String?

  @@index([taskId, changedAt])
}

model KpiSnapshot {
  id                String   @id @default(uuid())
  periodType        String // DAY, WEEK, MONTH
  periodStart       DateTime
  periodEnd         DateTime
  roleCode          String?
  coordinatorUserId String?
  supplierName      String?
  locationName      String?

  // Metrics
  totalCases          Int  @default(0)
  otifCases           Int  @default(0)
  onTimeCases         Int  @default(0)
  inFullCases         Int  @default(0)
  overdueCases        Int  @default(0)
  avgApprovalMinutes  Int?
  avgExecutionMinutes Int?

  // Rates
  otifRate   Float?
  onTimeRate Float?
  inFullRate Float?

  createdAt DateTime @default(now())

  @@index([periodType, periodStart, periodEnd])
  @@index([roleCode])
  @@index([coordinatorUserId])
  @@index([supplierName])
  @@index([locationName])
}

// ERP Integration Models

model RoutePlan {
  id              String   @id @default(uuid())
  destinationCode String   @unique
  destinationName String
  routeDay        String // MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY, SUNDAY
  prepOffsetDays  Int      @default(1) // Days before route day for preparation
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([routeDay])
  @@index([active])
}

model ErpImportBatch {
  id            String    @id @default(uuid())
  fileName      String
  status        String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  totalRows     Int       @default(0)
  processedRows Int       @default(0)
  errorRows     Int       @default(0)
  errors        String? // JSON string of errors
  importedBy    String? // User ID
  importedAt    DateTime  @default(now())
  completedAt   DateTime?

  erpDocuments ErpDocument[]

  @@index([status])
  @@index([importedAt])
}

model ErpDocument {
  id      String          @id @default(uuid())
  batchId String? // Optional for manual/event-created documents
  batch   ErpImportBatch? @relation(fields: [batchId], references: [id])

  sourceType   String // ERP_IMPORT, EMAIL, MANUAL
  documentType String // PURCHASE_ORDER, GOODS_RECEIPT, SALES_ORDER, SHIPMENT_ORDER

  documentNumber  String
  partnerName     String?
  partnerCode     String?
  destinationName String?
  destinationCode String?

  lineCount     Int       @default(0)
  totalQuantity Int       @default(0)
  plannedDate   DateTime?
  
  // Поврзан InboundItem за централна обработка
  inboundItemId       String?
  inboundItem       InboundItem? @relation("InboundErpDocument", fields: [inboundItemId], references: [id])

  // Tasks created from this document
  tasks Task[] @relation("ErpDocumentTasks")

  // Legacy - single task link
  taskId String? @unique // FK to Task

  // Raw data
  rawPayloadJson String? // Original row data as JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([documentType])
  @@index([plannedDate])
  @@index([documentNumber])
}

// Coordinator KPI tracking - stores monthly performance per coordinator
model CoordinatorKPI {
  id     String @id @default(uuid())
  userId String // FK to User
  user   User   @relation(fields: [userId], references: [id])

  month Int // 1-12
  year  Int // 2026

  // Auto-calculated from tasks
  tasksTotal   Int @default(0)
  tasksDone    Int @default(0)
  tasksPartial Int @default(0)
  tasksFailed  Int @default(0)
  tasksOverdue Int @default(0)
  tasksOnTime  Int @default(0)

  // Auto KPIs (calculated)
  accuracy       Int? // Delivery accuracy %
  otif           Int? // On-time in-full %
  prepOnTime     Int? // Prep on time %
  deliveryOnTime Int? // Delivery on time %
  avgCycleTime   Int? // Avg cycle time in minutes

  // Manual entry KPIs (monthly)
  tidiness     Int? // 0-100
  discipline   Int? // 0-100
  organization Int? // 0-100
  fuel         Int? // 0-100
  incidents    Int? // 0-100
  returns48h   Int? // 0-100

  // Role-specific scores (calculated)
  receptionScore    Int? // 0-100
  deliveryScore     Int? // 0-100
  distributionScore Int? // 0-100

  // Active role for this month (from user assignment)
  activeRole String? // RECEPTION_COORDINATOR, DELIVERY_COORDINATOR, DISTRIBUTION_COORDINATOR

  // Final score (based on active role)
  totalScore   Int? // 0-100
  bonusPercent Int? // 0, 40, 70, 100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
  @@index([month, year])
}

// ═══════════════════════════════════════════════════════════════════════════════════════════════════════
// AI Proposal Layer
// ═══════════════════════════════════════════════════════════════════════════════════════════════

model AiProposal {
  id                   String    @id @default(uuid())
  inboundItemId         String    @unique

  // Proposal version for schema evolution
  proposalVersion       String    @default("1.0")

  // Status tracking
  status               String    @default("GENERATED") // GENERATED, ACCEPTED, EDITED, REJECTED

  // Summary and recommendation
  summary              String?
  managerRecommendation  String    @default("NEEDS_REVIEW") // NEEDS_REVIEW, SAFE_TO_APPROVE, NEEDS_CLARIFICATION, REJECT_OR_IGNORE
  overallConfidence    String    @default("MEDIUM") // HIGH, MEDIUM, LOW

  // Request interpretation
  suggestedRequestType       String?
  requestTypeConfidence       Float?
  requestTypeBusinessMeaning  String?
  requiresManagerClarification Boolean @default(false)

  // Priority
  suggestedPriority  String? // LOW, MEDIUM, HIGH
  priorityReason     String?

  // Coordinator routing
  primaryCoordinatorType     String?
  secondaryCoordinatorTypes  String? // JSON array stored as string
  routingReason              String?

  // Extracted fields (JSON)
  extractedFieldsJson String?

  // Proposed tasks (JSON array)
  proposedTasksJson  String?

  // Data quality flags (JSON array)
  dataQualityFlagsJson String?

  // Decision hints (JSON)
  decisionHintsJson   String?

  // Raw reasoning
  rawReasoningSummary String?
  rawModelResponseJson String?

  // Model metadata
  modelName          String    @default("logitask-v1")
  temperature       Float     @default(0.2)

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([inboundItemId])
  @@index([status])
  @@index([overallConfidence])
}

// ═══════════════════════════════════════════════════════════════════════════════════════
// AI Feedback - Manager corrections
// ═══════════════════════════════════════════════════════════════════════════════════════

model AiFeedback {
  id                   String    @id @default(uuid())
  aiProposalId         String
  inboundItemId        String

  // Feedback type
  feedbackType         String    // ACCEPTED, CORRECTED, REJECTED

  // Original proposal snapshot
  originalProposalJson String?

  // Final decision snapshot
  finalDecisionJson    String?

  // Who provided feedback
  createdBy           String?

  // Additional feedback
  qualityRating      String? // EXCELLENT, GOOD, POOR
  feedbackText       String?

  createdAt          DateTime  @default(now())

  @@index([aiProposalId])
  @@index([inboundItemId])
  @@index([feedbackType])
}
